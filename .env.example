# ===========================================
# Database (Neon PostgreSQL)
# ===========================================
# Connection string dengan connection pooling (untuk aplikasi)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
# Direct connection (untuk migrasi Prisma)
DIRECT_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# ===========================================
# NextAuth.js
# ===========================================
# Secret untuk enkripsi session (generate: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-here"
# Base URL aplikasi
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# Amazon S3 (Media Storage)
# ===========================================
# AWS credentials untuk akses S3
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
# Region S3 bucket
AWS_REGION="ap-southeast-1"
# Nama S3 bucket untuk upload media
AWS_S3_BUCKET="your-s3-bucket-name"
